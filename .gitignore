# .gitignore — Foundry + envs

# Foundry
out/
cache/
broadcast/

# Env (matches every shape: .env, .env.local, .env.testnet, .env.production…)
.env
.env.*
!.env.example

# OS
.DS_Store

# Editor
.vscode/
.idea/

# Node (if examples grow)
node_modules/
package-lock.json

# Local deployment artifacts
deployments.local.json
