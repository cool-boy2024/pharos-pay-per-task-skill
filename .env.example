# Required: Pharos Atlantic testnet RPC
RPC=https://atlantic.dplabs-internal.com

# Required: 0x-prefixed private key with testnet PHRS for gas + escrow
# DO NOT REUSE A KEY THAT HAS HELD MAINNET FUNDS. Generate a fresh testnet key.
PRIVATE_KEY=0xYourTestnetKey

# Optional overrides for the deploy script (default to deployer)
ADMIN_ADDRESS=
PLATFORM_ADDRESS=
ECOSYSTEM_ADDRESS=

# Optional split overrides — must sum to 10000
CREATOR_BPS=8500
PLATFORM_BPS=1000
ECOSYSTEM_BPS=500

# Optional role hints used by SKILL.md pre-checks (purely informational —
# the contract itself authorizes by msg.sender, not these env values)
BUYER_ADDRESS=
AGENT_ADDRESS=
